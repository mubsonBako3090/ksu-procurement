{
      "name": "ksu-procurement-backend",
        "version": "1.0.0",
          "description": "KSU Digital Procurement Requisition System - Backend API",
            "main": "server.js",
              "scripts": {
                  "start":           "node server.js",
                      "dev":             "nodemon server.js",
                          "migrate":         "knex --knexfile database/knexfile.js migrate:latest",
                              "migrate:rollback":"knex --knexfile database/knexfile.js migrate:rollback",
                                  "seed":            "knex --knexfile database/knexfile.js seed:run",
                                      "test":            "jest --runInBand --forceExit"
                                        },
                                          "dependencies": {
                                              "axios":                "^1.6.2",
                                                  "bcryptjs":             "^2.4.3",
                                                      "cloudinary":           "^1.41.0",
                                                          "cors":                 "^2.8.5",
                                                              "dotenv":               "^16.3.1",
                                                                  "express":              "^4.18.2",
                                                                      "express-async-errors": "^3.1.1",
                                                                          "helmet":               "^7.1.0",
                                                                              "joi":                  "^17.11.0",
                                                                                  "jsonwebtoken":         "^9.0.2",
                                                                                      "knex":                 "^3.1.0",
                                                                                          "morgan":               "^1.10.0",
                                                                                              "multer":               "^1.4.5-lts.1",
                                                                                                  "nodemailer":           "^6.9.7",
                                                                                                      "pdfkit":               "^0.14.0",
                                                                                                          "pg":                   "^8.11.3",
                                                                                                              "winston":              "^3.11.0"
                                                                                                                },
                                                                                                                  "devDependencies": {
                                                                                                                      "jest":      "^29.7.0",
                                                                                                                          "nodemon":   "^3.0.2",
                                                                                                                              "supertest": "^6.3.3"
                                                                                                                                }
                                                                                                                                }
}